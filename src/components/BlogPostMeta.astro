---
interface Props {
  author?: string;
  publishDate: Date;
  updatedDate?: Date;
}

const { publishDate } = Astro.props;

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}
---

<div class="text-center text-muted-foreground font-display text-lg uppercase tracking-wider mb-8">
  {formatDate(publishDate)}
</div>
