---
import { AugurLogo } from "./icons.tsx";
import Button from "./ui/Button.tsx";
import { withBase } from "../lib/utils";
---

<footer class="relative px-4 md:px-8 mt-4">
  <div class="max-w-7xl mx-auto">
    <div class="border border-primary/10 bg-background/70 p-8 md:p-12 mb-8">
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1fr_max-content_max-content_max-content] gap-12"
      >
        <!-- Column 1: Logo & Tagline -->
        <div class="md:col-span-2 lg:col-span-1 lg:place-content-end">
            <div class="text-center lg:w-max">
                <Button variant="link" href={withBase('/?intro=false')} className="flex flex-col gap-y-2 group">
                    <!-- Footer Logo (White) -->
                    <AugurLogo className="text-8xl" />
                    <span class:list={[
                      "text-xl font-display text-muted-foreground mt-1 leading-none tracking-wider font-light uppercase",
                      " group-hover:text-loud-foreground group-focus:text-loud-foreground"
                    ]}>
                        THE FRONTIER OF <br class="hidden lg:inline" />PREDICTION MARKETS
                    </span>
                </Button>
            </div>
        </div>
        <!-- Column 2: Social -->
        <div>
          <h4 class="text-muted-foreground mb-4 font-display">&gt;_ SOCIAL</h4>
          <ul class="space-y-2">
            <li>
              <Button variant="link" href="https://github.com/AugurProject/">
                GITHUB
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://x.com/AugurProject">
                X.COM (TWITTER)
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://discord.gg/Y3tCZsSmz3">
                DISCORD
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://t.me/augurlituus">
                TELEGRAM
              </Button>
            </li>
          </ul>
        </div>
        <!-- Column 3: REP -->
        <div>
          <h4 class="text-muted-foreground mb-4 font-display">&gt;_ REP</h4>
          <ul class="space-y-2">
            <li>
              <Button variant="link" href="https://etherscan.io/token/0x221657776846890989a759ba2973e427dff5c9bb">
                REPV2 (ETHERSCAN)
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://etherscan.io/token/0x1985365e9f78359a9B6AD760e32412f4a445E862">
                REPV1 (ETHERSCAN)
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://pro.kraken.com/app/trade/rep-usd">
                REPV1/USD (KRAKEN)
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://pro.kraken.com/app/trade/repv2-usd">
                REPV2/USD (KRAKEN)
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://pro.kraken.com/app/trade/repv2-eur">
                REPV2/EUR (KRAKEN)
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://app.uniswap.org/tokens/ethereum/0x221657776846890989a759ba2973e427dff5c9bb">
                REPV2 UNISWAP
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://www.geckoterminal.com/eth/tokens/0x221657776846890989a759ba2973e427dff5c9bb">
                REPV2 UNISWAP GECKO UI
              </Button>
            </li>
          </ul>
        </div>
        <!-- Column 4: Companies & KB -->
        <div>
          <h4 class="text-muted-foreground mb-4 font-display">&gt;_ COMPANIES</h4>
          <ul class="space-y-2 mb-6">
            <li>
              <Button variant="link" href="#">
                THE DARK FLORIST
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://lituus.foundation">
                LITUUS FOUNDATION
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://x.com/AugurLituus">
                @AUGURLITUUS
              </Button>
            </li>
          </ul>
          <h4 class="text-muted-foreground mb-4 font-display">&gt;_ KB</h4>
          <ul class="space-y-2">
            <li>
              <Button variant="link" href={withBase('/faq')}>
                FORK & MIGRATION FAQ
              </Button>
            </li>
            <li>
              <Button variant="link" href="https://docs.google.com/viewer?url=https://github.com/AugurProject/whitepaper/releases/download/v2.0.6/augur-whitepaper-v2.pdf">
                AUGUR WHITEPAPER
              </Button>
            </li>
          </ul>
        </div>
      </div>
    </div>
    <div
      class="flex flex-col md:flex-row justify-between items-center gap-4 pb-8"
    >
      <p class="font-display text-foreground">© 2026 AUGUR. ALL RIGHTS RESERVED.</p>
      <nav class="flex gap-8">
        <Button variant="link" href={withBase('/terms')}>
          TERMS OF SERVICE
        </Button>
        <Button variant="link" href={withBase('/privacy')}>PRIVACY POLICY</Button>
      </nav>
    </div>
  </div>
</footer>
