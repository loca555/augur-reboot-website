---
export interface Props {
  text: string;
  class?: string;
}

const { text, class: className = "" } = Astro.props;
---

<div class="flex justify-center mb-6">
  <h2 class={`text-foreground font-display tracking-wide font-light uppercase border border-muted-foreground/40 px-3 py-1 ${className}`}>
    {text}
  </h2>
</div>
