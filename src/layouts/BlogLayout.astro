---
import Layout from "../layouts/Layout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import Footer from "../components/Footer.astro";
import BlogNavigation from "../components/BlogNavigation.tsx";
import BlogPostMeta from "../components/BlogPostMeta.astro";
import Button from "../components/ui/Button.tsx";
import Pointer from "../components/Pointer.tsx";
import { withBase } from "../lib/utils";

interface Post {
  title: string;
  path: string;
}

interface Props {
  title: string;
  description?: string;
  author: string;
  publishDate: Date;
  updatedDate?: Date;
  ogImage?: string;
  postUrl?: string;
  prevPost?: Post;
  nextPost?: Post;
}

const { title, description, author, publishDate, updatedDate, ogImage, postUrl, prevPost, nextPost } = Astro.props;
---

<Layout
  title={`${title} - The Augur Blog`}
  description={description}
  ogImage={ogImage}
  ogType="article"
>
  <div class="grid grid-rows-[auto_1fr_auto] min-h-screen">
    {/* Top Section: Navigation */}
    <div class="flex justify-between items-start p-8">
      {/* Back Button */}
      <Button id="back-button" variant="link" href={withBase('/?intro=false')} auto-focus>
        <Pointer direction="left" animated="auto" />
        BACK TO HOME
      </Button>

      {/* Social Links */}
      <SocialLinks />
    </div>

    {/* Middle Section: Scrollable Content */}
    <main class="overflow-y-auto px-4 md:px-8 mb-12">
      <div class="max-w-2xl mx-auto">
        <h1 class="text-center uppercase text-2xl mb-4">
          <span class="text-muted-foreground">BLOG</span>
          <span class="text-muted-foreground mx-2">//</span>
          <span class="text-loud-foreground font-bold">{title}</span>
        </h1>
        <BlogPostMeta
          author={author}
          publishDate={publishDate}
          updatedDate={updatedDate}
        />

        {/* Main Content */}
        <article class="prose prose-sm prose-invert max-w-none pt-6 px-4">
          <slot />
        </article>
      </div>
    </main>

    {/* Bottom Section: Navigation + Footer */}
    <BlogNavigation client:load prevPost={prevPost} nextPost={nextPost} />
    <Footer />
  </div>

  <style is:global>
    /* Custom prose styles for dark mode - Tailwind v4 CSS-first approach */
    .prose {
      --tw-prose-headings: var(--color-loud-foreground);
      --tw-prose-links: var(--color-primary);
      --tw-prose-body: var(--color-foreground);
      --tw-prose-bold: var(--color-foreground);
      --tw-prose-code: var(--color-green-400);
      --tw-prose-borders: var(--color-primary);
      --tw-prose-td-borders: var(--color-muted-foreground);
      --tw-prose-th-borders: var(--color-muted-foreground);
      --tw-prose-bg-hover: var(--color-primary);
      --tw-prose-line-height: 1.2;
      --tw-prose-pre-bg: transparent;
      --tw-prose-pre-code: var(--color-foreground);
    }

    .prose-sm {
      line-height: 1.5em;
      font-size: 0.825rem;
    }

    .prose :is(h1, h2, h3, h4, h5, h6) {
      text-transform: uppercase;
    }

    .prose :is(h1, h2, h3, h4, h5, h6):has(.heading-icon) {
      display: inline-flex;
      align-items: center;
    }

    .prose :is(h2, h3, h4, h5, h6) .heading-icon {
      display: inline-block;
      width: 1em;
      height: 1em;
      margin-right: 0.375em;
      vertical-align: middle;
    }

    .prose h1 {
      font-size: 1.5rem;
    }

    .prose p {
      font-family: var(--tw-prose-p-font-family);
    }

    .prose li {
      font-family: var(--tw-prose-p-font-family);
    }

    .prose ul {
      list-style-type: square;
    }

    .prose ul > li::marker {
      color: var(--color-muted-foreground);
    }

    .prose ol > li::marker {
      color: var(--color-muted-foreground);
    }

    .prose table td {
      font-family: var(--tw-prose-p-font-family);
    }

    /* Override Shiki syntax highlighting theme for code blocks */
    .prose pre.astro-code {
      background-color: transparent !important;
      border: none;
      padding: 0;
    }

    .prose pre.astro-code code {
      color: var(--color-foreground);
    }

    /* Blockquote styling */
    .prose blockquote {
      border-left-color: var(--color-muted-foreground);
    }

    .prose blockquote p {
      color: var(--color-foreground);
    }

    .prose img {
      border: 1px solid oklch(from var(--color-muted-foreground) l c h / 0.3);
      box-shadow: 0 0 2em oklch(from var(--color-primary) l c h / 0.1);
    }

    /* Top-left accent on the first child of the article */
    .prose > :first-child {
      position: relative;
    }

    .prose > :first-child + p:has(img)::after,
    .prose > :first-child::before {
        position: absolute;
        content: '';
        width: 2rem;
        height: 2rem;
    }

    .prose > :first-child::before {
      top: -1rem;
      left: -1rem;
      border-top: 1px solid var(--color-muted-foreground);
      border-left: 1px solid var(--color-muted-foreground);
    }

    /* Bottom-right accent on the first image's container */
    .prose > :first-child + p:has(img) {
      position: relative;
    }

    .prose > :first-child + p:has(img)::after {
      bottom: -1rem;
      right: -1rem;
      border-bottom: 1px solid var(--color-muted-foreground);
      border-right: 1px solid var(--color-muted-foreground);
    }
  </style>
</Layout>
