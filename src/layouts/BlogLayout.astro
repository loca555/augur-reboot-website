---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import BlogNavigation from "../components/BlogNavigation.tsx";
import BlogPostMeta from "../components/BlogPostMeta.astro";
import PageHeader from "../components/PageHeader.tsx";
import PageTitle from "../components/PageTitle.astro";
import { withBase } from "../lib/utils";

interface Post {
  title: string;
  path: string;
}

interface Props {
  title: string;
  description?: string;
  author: string;
  publishDate: Date;
  updatedDate?: Date;
  ogImage?: string;
  postUrl?: string;
  prevPost?: Post;
  nextPost?: Post;
}

const { title, description, author, publishDate, updatedDate, ogImage, prevPost, nextPost } = Astro.props;
---

<Layout
  title={`${title} - The Augur Blog`}
  description={description}
  ogImage={ogImage}
  ogType="article"
>
  <div class="grid grid-rows-[auto_1fr_auto] min-h-screen">
    {/* Top Section: Navigation */}
    <PageHeader client:load backHref={withBase('/?intro=false')} />

    {/* Middle Section: Scrollable Content */}
    <main class="overflow-y-auto px-4 md:px-8 pt-8 mb-12">
      <div class="max-w-3xl mx-auto">
        <PageTitle prefix="BLOG" title={title} />
        <BlogPostMeta
          author={author}
          publishDate={publishDate}
          updatedDate={updatedDate}
        />

        {/* Main Content */}
        <article class="prose prose-invert max-w-none pt-6 px-4 prose-headings:font-display prose-headings:uppercase prose-headings:tracking-wide prose-p:leading-snug prose-li:leading-snug prose-ul:list-[square] prose-li:marker:text-muted-foreground prose-ol:marker:text-muted-foreground prose-blockquote:border-l-muted-foreground prose-blockquote:text-foreground prose-img:border prose-img:border-muted-foreground/30 prose-img:shadow-[0_0_2em_oklch(from_var(--color-primary)_l_c_h_/0.1)]">
          <slot />
        </article>
      </div>
    </main>

    {/* Bottom Section: Navigation + Footer */}
    <BlogNavigation client:load prevPost={prevPost} nextPost={nextPost} />
    <Footer />
  </div>

  <style is:global>
    /* Corner accent decorations for blog post articles */
    .prose > :first-child {
      position: relative;
    }

    .prose > :first-child + p:has(img)::after,
    .prose > :first-child::before {
        position: absolute;
        content: '';
        width: 2rem;
        height: 2rem;
    }

    .prose > :first-child::before {
      top: -1rem;
      left: -1rem;
      border-top: 1px solid var(--color-muted-foreground);
      border-left: 1px solid var(--color-muted-foreground);
    }

    .prose > :first-child + p:has(img) {
      position: relative;
    }

    .prose > :first-child + p:has(img)::after {
      bottom: -1rem;
      right: -1rem;
      border-bottom: 1px solid var(--color-muted-foreground);
      border-right: 1px solid var(--color-muted-foreground);
    }
  </style>
</Layout>
