---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import PageHeader from "../components/PageHeader.tsx";
import AsciiText from "../components/AsciiText.tsx";
import Pointer from "../components/Pointer.tsx";
import { withBase } from "../lib/utils";
---

<Layout title="404: Page Not Found - Augur">
  <div class="flex flex-col">
    <!-- Main content wrapper that fills viewport -->
    <div class="min-h-screen flex flex-col">
      <!-- Top Section: Navigation -->
      <PageHeader client:load backHref={withBase('/?intro=false')} />

      <!-- Middle Section: 404 Content -->
      <main class="flex-1 flex items-center justify-center px-4 md:px-8">
        <div class="text-center max-w-2xl mx-auto flex flex-col items-center">
          <h1 class="font-display uppercase mb-4 text-2xl font-bold tracking-widest">Page Not Found</h1>
          <!-- ASCII Art 404 -->
          <AsciiText client:load animated className="tracking-tight text-[clamp(0.8rem,1vw,0.9rem)] fx-glow-sm max-w-full overflow-hidden mx-auto" label="404 - Page Not Found" content={`‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
     ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ     ‚Ėą‚Ėą‚ēĎ
     ‚ēö‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ      ‚ēö‚ēź‚ēĚ`} />

          <!-- Error Message -->
          <div class="border border-foreground/20 bg-background/70 px-6 py-4 mx-auto max-w-sm my-6">
            <p class="font-display uppercase text-muted-foreground leading-6">
              The oracle has spoken: <span class="text-loud-foreground">This page does not exist in our reality</span>. Perhaps it's in an alternate timeline, or maybe the prediction market for its existence resolved to FALSE.
            </p>
          </div>

          <!-- Navigation Message -->
          <div class="text-center space-y-4">
            <p class="text-sm uppercase text-muted-foreground opacity-80">
              Return to the homepage by <a href={withBase("/?intro=false")} class="text-loud-foreground hover:fx-glow-sm transition-all">clicking here</a> <br />
              or scroll further down to explore community links.
            </p>

            <!-- Animated Down Arrow -->
            <div class="flex justify-center">
              <Pointer animated="always" direction="down" />
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Footer outside the viewport -->
    <Footer />
  </div>
</Layout>
